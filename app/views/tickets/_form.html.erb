<%= form_with model: ticket, class: "space-y-4" do |f| %>
  <% if ticket.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 rounded p-4">
      <p class="font-semibold"><%= ticket.errors.count %> erro(s) impediram o salvamento:</p>
      <ul class="list-disc list-inside text-sm">
        <% ticket.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "Titulo", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title, class: "w-full border rounded px-3 py-2" %>
  </div>

  <div>
    <%= f.label :description, "Descricao", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 4, class: "w-full border rounded px-3 py-2" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :priority, "Prioridade", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :priority,
          Ticket.priorities.keys.map { |p| [p.humanize, p] },
          {}, class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :status,
          Ticket.statuses.keys.map { |s| [s.humanize, s] },
          {}, class: "w-full border rounded px-3 py-2" %>
    </div>
  </div>

  <div>
    <%= f.label :agent_id, "Responsavel", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.collection_select :agent_id, Agent.order(:name), :id, :name,
        { include_blank: "Selecione..." }, class: "w-full border rounded px-3 py-2" %>
    <p class="text-xs text-gray-500 mt-1">
      Deixe em branco e use "Atribuir automaticamente" na tela do chamado para o sistema escolher.
    </p>
  </div>

  <div class="flex gap-3">
    <%= f.submit "Salvar", class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Cancelar", tickets_path, class: "px-4 py-2 text-gray-600 underline" %>
  </div>
<% end %>
