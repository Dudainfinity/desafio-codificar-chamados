<div class="max-w-2xl mx-auto p-6">
  <div class="mb-4">
    <%= link_to "← Voltar para a lista", tickets_path, class: "text-blue-600 hover:underline text-sm" %>
  </div>

  <div class="bg-white rounded shadow p-6 space-y-4">
    <div class="flex items-start justify-between">
      <h1 class="text-2xl font-bold text-gray-800"><%= @ticket.title %></h1>
      <span class="text-sm text-gray-500">
        Aberto em <%= @ticket.created_at.strftime("%d/%m/%Y %H:%M") %>
      </span>
    </div>

    <p class="text-gray-700 whitespace-pre-line"><%= @ticket.description.presence || "Sem descricao." %></p>

    <div class="grid grid-cols-3 gap-4 border-t pt-4 text-sm">
      <div>
        <span class="block text-gray-500">Prioridade</span>
        <span class="font-medium"><%= @ticket.priority.humanize %></span>
      </div>
      <div>
        <span class="block text-gray-500">Status</span>
        <span class="font-medium"><%= @ticket.status.humanize %></span>
      </div>
      <div>
        <span class="block text-gray-500">Responsavel</span>
        <span class="font-medium"><%= @ticket.agent.name %></span>
      </div>
    </div>

    <div class="border-t pt-4 flex flex-wrap gap-3">
      <%= link_to "Editar", edit_ticket_path(@ticket),
          class: "bg-gray-700 text-white px-4 py-2 rounded hover:bg-gray-800" %>

      <%= button_to "Atribuir automaticamente", assign_auto_ticket_path(@ticket),
          method: :patch,
          class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700" %>

      <%= button_to "Remover", @ticket,
          method: :delete,
          data: { turbo_confirm: "Tem certeza que deseja remover este chamado?" },
          class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700" %>
    </div>
  </div>
</div>
